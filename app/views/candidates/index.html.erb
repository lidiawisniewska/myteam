<div class="container">
  <p class="notice"><%= notice %></p>
  <div class="row">
    <div class="col-md-6 logo">myteam</div>
    <div class="col-md-6" id="navbar">
      <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "btn btn-link" %>
    </div>
  </div>
</div>

<div class="container">
<table>
  <thead>
    <tr>
      <th>Avatar</th>
      <th>Email</th>
      <th>First name</th>
      <th>Last name</th>
      <th>Employment</th>
      <th>Role</th>
      <th>LinkedIn</th>
      <th>Facebook</th>
      <th>Twitter</th>
      <th>Team</th>
      <th>CV</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @candidates.each do |candidate| %>
      <tr>
        <td><%= candidate_avatar(candidate) %></td>
        <td><%= candidate.email %></td>
        <td><%= candidate.first_name %></td>
        <td><%= candidate.last_name %></td>
        <td><%= candidate.company %></td>
        <td><%= candidate_role(candidate) %></td>
        <td><%= candidate_linkedin_url(candidate) %></td>
        <td><%= candidate_facebook_url(candidate) %></td>
        <td><%= candidate_twitter_url(candidate) %></td>
        <td><%= candidate.team %></td>
        <td>
          <% if candidate.cv.attached? %>
            <%= link_to 'CV', rails_blob_path(candidate.cv, disposition: 'attachment'), target: '_blank' %>
          <% else %>
            n/a
          <% end %>
        </td>
        <td>
          <%= link_to 'Edit', edit_candidate_path(candidate) %><br/>
          <%= button_to 'Delete', candidate, method: :delete,
                data: { turbo_confirm: 'Are you sure?' },
                class: "btn btn-link" %><br/>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<p><%= link_to 'Add New Candidate', new_candidate_path %></p>
</div>
